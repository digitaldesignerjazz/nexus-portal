# Nexus Portal - Comprehensive .gitignore
# Covers common languages and tools for web portals, AI/ML, Rust, Python, mesh/blockchain dev

# =========================
# Dependencies
# =========================
node_modules/
pnpm-lock.yaml
yarn.lock
package-lock.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Rust / Cargo
/target/
**/*.rs.bk
Cargo.lock

# Go
bin/
pkg/

# =========================
# Build Outputs & Artifacts
# =========================
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/

# =========================
# Environment & Secrets (Critical for privacy-focused project)
# =========================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json
config/local.*

# =========================
# IDE / Editor / OS Files
# =========================
.vscode/
.idea/
*.swp
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
ehthumbs.db
ehthumbs_vista.db

# =========================
# Logs & Debug
# =========================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# =========================
# Testing & Coverage
# =========================
/coverage
.nyc_output
*.lcov
.grunt

# =========================
# Temporary & Cache
# =========================
.cache/
.temp/
.tmp/
*.tmp
*.bak

# =========================
# Project-Specific
# =========================
# Uploaded starter archives
nexus-portal-starter*.zip
starter*.zip

# Mesh / Networking specific (examples)
*.pid
*.sock
yggdrasil.*.conf

# Blockchain / Crypto artifacts (if generated locally)
*.wallet
keystore/

# AI / Agent artifacts
agent_logs/
swarm_state/
model_cache/

# =========================
# Misc
# =========================
# Add project-specific ignores here as the stack is chosen
